{
    "name": "wingtechbot-mk3-monorepo",
    "version": "1.0.0",
    "description": "WingTechBot MK3 monorepo with backend and frontend",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "pnpm --filter backend dev",
        "dev:frontend": "pnpm --filter frontend dev",
        "dev:all": "pnpm --parallel dev dev:frontend",
        "build": "pnpm --recursive build",
        "build:backend": "pnpm --filter backend build",
        "build:frontend": "pnpm --filter frontend build",
        "build:types": "pnpm --filter types build",
        "test": "pnpm --recursive test",
        "test:backend": "pnpm --filter backend test",
        "test:frontend": "pnpm --filter frontend test",
        "lint": "pnpm --recursive lint",
        "lint:fix": "pnpm --recursive lint:fix",
        "format": "pnpm --recursive format",
        "format:check": "pnpm --recursive format:check",
        "clean": "pnpm -r clean",
        "db:generate": "pnpm --filter backend db:generate",
        "db:migrate": "pnpm --filter backend db:migrate",
        "docker:build": "docker build -t wingtechbot-mk3 -f packages/backend/Dockerfile .",
        "docker:up": "pnpm --filter backend predev && pnpm --filter backend docker:up",
        "docker:up:detached": "pnpm --filter backend docker:up:detached",
        "docker:down": "pnpm --filter backend docker:down",
        "docker:down:clean": "pnpm --filter backend docker:down:volumes",
        "docker:logs": "pnpm --filter backend docker:logs",
        "docker:restart": "pnpm --filter backend docker:restart",
        "docker:clean": "pnpm --filter backend docker:clean",
        "docs:dev": "pnpm --filter docs dev",
        "docs:build": "pnpm --filter docs build",
        "docs:preview": "pnpm --filter docs preview",
        "prepare": "husky"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@tailwindcss/postcss": "^4.1.18",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@typescript-eslint/eslint-plugin": "^8.53.1",
        "@typescript-eslint/parser": "^8.53.1",
        "@vitejs/plugin-react": "^5.1.2",
        "autoprefixer": "^10.4.23",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.26",
        "globals": "^16.5.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "postcss": "^8.5.15",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "rimraf": "^6.1.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.53.1",
        "vite": "^7.3.5"
    },
    "pnpm": {
        "overrides": {
            "jws": ">=4.0.1",
            "body-parser": ">=2.2.1",
            "qs": ">=6.14.2",
            "diff@<8.0.3": ">=8.0.3",
            "tar": ">=7.5.16",
            "protobufjs": ">=7.5.5",
            "@protobufjs/utf8": ">=1.1.1",
            "@isaacs/brace-expansion": ">=5.0.1",
            "brace-expansion@<1.1.13": ">=1.1.13",
            "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
            "minimatch": ">=10.2.3",
            "rollup": ">=4.59.0",
            "ajv": ">=6.14.0",
            "flatted": ">=3.4.0",
            "picomatch": ">=4.0.4",
            "yaml": ">=2.8.3",
            "path-to-regexp": ">=8.4.0",
            "lodash-es": ">=4.18.0",
            "lodash": ">=4.18.0",
            "immutable": ">=4.3.8",
            "ws": ">=8.20.1",
            "js-yaml": ">=4.2.0",
            "@babel/core": ">=7.29.6",
            "undici": ">=6.27.0"
        }
    }
}
